# Server
NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/adoptame

# JWT (genera con: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_min_32_chars_here_change_this
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Frontend
FRONTEND_URL=http://localhost:3000

# Cloudflare R2 (para fotos de mascotas)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=adoptame-media
R2_PUBLIC_URL=https://media.adoptame.app

# Resend (emails transaccionales)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@adoptame.app
